# Copiá este archivo como secrets.toml y completá con tus credenciales.
# NUNCA subas secrets.toml a GitHub — ya está en .gitignore.
#
# Obtenés la URL en: Supabase → Settings → Database → Connection string → URI
# Reemplazá [YOUR-PASSWORD] con la contraseña de tu proyecto.

[db]
url = "postgresql://postgres:[YOUR-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres"
